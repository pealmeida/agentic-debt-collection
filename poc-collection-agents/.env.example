# OpenRouter API key (obrigatório para modo real; sem ela a POC roda em simulação)
# Obtenha em: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Model profile (escolhe um conjunto coeso de modelos + estratégia JSON + pricing).
# Valores válidos: gemini-flash-lite | openai-blend | claude-haiku
# Veja config/harness_negotiator.yaml → model_profiles para a lista completa.
OPENROUTER_MODEL_PROFILE=gemini-flash-lite

# Legacy: força o mesmo slug em todos os agentes (sobrepõe o profile).
# Útil para A/B rápido de modelos sem editar o YAML. Deixe vazio para usar o profile.
# Exemplos: openai/gpt-4o-mini, anthropic/claude-3.5-haiku, google/gemini-2.5-flash-lite
OPENROUTER_DEFAULT_MODEL=
