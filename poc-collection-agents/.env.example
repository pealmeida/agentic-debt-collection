# OpenRouter API key (obrigatório para modo real; sem ela a POC roda em simulação)
# Obtenha em: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Modelo padrão (opcional — sobrescreve todos os agentes)
# Exemplos: openai/gpt-4o-mini, openai/gpt-4o, anthropic/claude-3.5-sonnet
OPENROUTER_DEFAULT_MODEL=

# Habilitar BYOK (usuário passa sua chave via header x-byok-key)
ALLOW_BYOK=true
